# OpenAI-compatible LLM API
OPENAI_API_KEY=sk-your-api-key
# Leave empty to use the official OpenAI endpoint.
BASE_URL=

# Models used by each agent
PLANNER_MODEL=gpt-4o-mini
VERIFIER_MODEL=gpt-4o-mini
LINK_MODEL=gpt-4o-mini
VLM_MODEL=gpt-4o-mini

# Thresholds and budgets
CONF_THRESHOLD=0.75
MAX_ITERATIONS=3
MAX_TOTAL_TOKENS_PER_PAPER=60000
LINK_BATCH_SIZE=8
VERIFIER_BATCH_SIZE=12
LLM_TIMEOUT=120
LLM_RETRIES=1

# Optional integrations and features
OPENALEX_MAILTO=you@example.com
# Optional IEEE Xplore application key; Crossref/OpenAlex remain usable without it.
IEEE_API_KEY=
ENABLE_PDF_AGENT=0
